# 資料庫（Zeabur 會自動注入 DATABASE_URL）
DATABASE_URL=postgresql://user:password@localhost:5432/posdb

# Google Sheets
GOOGLE_SHEET_ID=你的_Sheet_ID
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Email via Zeabur Email
ZEABUR_EMAIL_API_KEY=zs_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=report@yourdomain.com
EMAIL_RECIPIENTS=jason@example.com,partner@example.com

# Webhook 安全驗證（可選）
WEBHOOK_SECRET=
